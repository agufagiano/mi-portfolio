---
const { titulo, categoria, imagen, slug, index } = Astro.props
---

<article class="card" style={`animation-delay: ${index * 0.1}s`}>
  <a href={`/proyectos/${slug}`}>
    <div class="imagen-wrapper">
      <img src={imagen} alt={titulo} loading="lazy" />
      <div class="overlay">
        <span>Ver proyecto →</span>
      </div>
    </div>
    <div class="info">
      <span class="categoria">{categoria}</span>
      <h3>{titulo}</h3>
    </div>
  </a>
</article>

<style>
  .card {
    opacity: 0;
    animation: fadeUp 0.7s ease forwards;
  }

  a { display: block; }

  .imagen-wrapper {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4/3;
    background: #e8e5e0;
  }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: rgba(15, 15, 15, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .overlay span {
    color: var(--blanco);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .card:hover img { transform: scale(1.04); }
  .card:hover .overlay { opacity: 1; }

  .info {
    padding: 1.2rem 0 0;
  }

  .categoria {